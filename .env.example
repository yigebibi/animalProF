# 项目基本配置
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# 前端配置
VITE_API_URL=http://localhost:3000/api/v1
VITE_ENV=development
VITE_APP_TITLE=宠物论坛 - 开发环境

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=petforum
DB_USER=petforum
DB_PASSWORD=petforum123
DATABASE_URL=postgresql://petforum:petforum123@localhost:5432/petforum?schema=public

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT 配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 阿里云 OSS 配置（可选）
OSS_ACCESS_KEY_ID=your-access-key
OSS_ACCESS_KEY_SECRET=your-access-secret
OSS_BUCKET=petforum
OSS_REGION=oss-cn-hangzhou

# 邮件服务配置（可选）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email
SMTP_PASS=your-password
SMTP_FROM=noreply@petforum.com

# 短信服务配置（可选）
SMS_ACCESS_KEY_ID=your-sms-key
SMS_ACCESS_KEY_SECRET=your-sms-secret
SMS_SIGN_NAME=宠物论坛
SMS_TEMPLATE_CODE=SMS_123456789

# RabbitMQ 配置（可选）
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Socket.io 配置
SOCKET_PORT=3000

# 监控配置
SENTRY_DSN=your-sentry-dsn

# 开发工具
DEBUG=false
LOG_LEVEL=info
